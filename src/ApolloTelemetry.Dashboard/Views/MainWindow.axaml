<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ApolloTelemetry.Dashboard.ViewModels"
        x:Class="ApolloTelemetry.Dashboard.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ApolloTelemetry" Width="550" Height="650"
        Background="#121212">

    <ScrollViewer>
        <StackPanel Margin="25" Spacing="20">
            <StackPanel Spacing="5">
                <TextBlock Text="SERVER STATUS" Foreground="Gray" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                <TextBlock Text="{Binding Stats.DeviceName, FallbackValue='OFFLINE'}" 
                           Foreground="White" FontSize="32" FontWeight="Bold"/>
                
                <StackPanel Orientation="Horizontal" Spacing="15">
                    <TextBlock Text="{Binding Stats.Uptime, StringFormat='UPTIME: {0}'}" 
                               Foreground="#00FF00" FontSize="12" FontWeight="Medium"/>
                    <TextBlock Text="{Binding Stats.OSVersion, StringFormat='OS: {0}'}" 
                               Foreground="#AAAAAA" FontSize="12"/>
                </StackPanel>
            </StackPanel>

            <Separator Background="#333333"/>

            <StackPanel Spacing="10">
                <TextBlock Text="RESOURCES" Foreground="Gray" FontSize="10" FontWeight="Bold"/>
                
                <Border Background="#1E1E1E" Padding="12" CornerRadius="8">
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBlock Text="CPU Cores" Foreground="White"/>
                        <TextBlock Grid.Column="1" Text="{Binding Stats.ProcessorCount}" Foreground="Cyan" FontWeight="Bold"/>
                    </Grid>
                </Border>

                <Border Background="#1E1E1E" Padding="12" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="System Memory (RAM)" Foreground="White"/>
                            <TextBlock Grid.Column="1" Text="{Binding MemoryDisplay}" Foreground="MediumPurple" FontWeight="Bold"/>
                        </Grid>
                        <ProgressBar Value="{Binding MemoryUsedBytes}" 
                                     Maximum="{Binding Stats.TotalMemoryBytes}" 
                                     Height="8" Foreground="MediumPurple" Background="#333333" CornerRadius="4"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="15">
                <TextBlock Text="STORAGE UNITS" Foreground="Gray" FontSize="10" FontWeight="Bold"/>
                
                <ItemsControl ItemsSource="{Binding Stats.Drives}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBlock Text="{Binding Name}" Foreground="Orange" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding UsedPercentage, StringFormat={}{0}% Used}" 
                                                   Foreground="Gray" FontSize="12"/>
                                    </Grid>
                                    <ProgressBar Value="{Binding UsedPercentage}" 
                                                 Height="8" Minimum="0" Maximum="100" 
                                                 Foreground="#FF4500" Background="#333333" CornerRadius="4"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>