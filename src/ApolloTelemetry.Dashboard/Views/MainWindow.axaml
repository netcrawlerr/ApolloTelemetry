<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ApolloTelemetry.Dashboard.ViewModels"
        x:Class="ApolloTelemetry.Dashboard.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ApolloTelemetry" Width="550" Height="750"
        Background="#121212">

    <Window.Styles>
        <Style Selector="Ellipse.statusDot">
            <Setter Property="Fill" Value="#444444" />
        </Style>
        <Style Selector="Ellipse.statusDot[Tag=Running]">
            <Setter Property="Fill" Value="#00FF00" />
        </Style>
        <Style Selector="Ellipse.statusDot[Tag=Stopped]">
            <Setter Property="Fill" Value="#FF4500" />
        </Style>

        <Style Selector="TextBlock.statusText">
            <Setter Property="Foreground" Value="Gray" />
        </Style>
        <Style Selector="TextBlock.statusText[Text=Running]">
            <Setter Property="Foreground" Value="#00FF00" />
        </Style>
    </Window.Styles>

    <ScrollViewer>
        <StackPanel Margin="25" Spacing="20">
            <StackPanel Spacing="5">
                <TextBlock Text="SERVER STATUS" Foreground="Gray" FontSize="10" FontWeight="Bold" />
                <TextBlock Text="{Binding Stats.DeviceName, FallbackValue='CONNECTING...'}"
                           Foreground="White" FontSize="32" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="15">
                    <TextBlock Text="{Binding Stats.Uptime, StringFormat='UPTIME: {0}'}" Foreground="#00FF00" FontSize="12" />
                    <TextBlock Text="{Binding Stats.OSVersion, StringFormat='OS: {0}'}" Foreground="#AAAAAA" FontSize="12" />
                </StackPanel>
            </StackPanel>

            <Separator Background="#333333" />

            <StackPanel Spacing="10">
                <TextBlock Text="DATABASE SERVICES" Foreground="Gray" FontSize="10" FontWeight="Bold" />
                <UniformGrid Columns="2">
                    <Border Background="#1E1E1E" CornerRadius="8" Padding="12" Margin="5" Height="65">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Ellipse Width="10" Height="10" Classes="statusDot" Tag="{Binding MySqlStatus}"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="MySQL" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="{Binding MySqlStatus}" Classes="statusText" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#1E1E1E" CornerRadius="8" Padding="12" Margin="5" Height="65">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Ellipse Width="10" Height="10" Classes="statusDot" Tag="{Binding PostgreSqlStatus}"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="PostgreSQL" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="{Binding PostgreSqlStatus}" Classes="statusText" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#1E1E1E" CornerRadius="8" Padding="12" Margin="5" Height="65">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Ellipse Width="10" Height="10" Classes="statusDot" Tag="{Binding MsSqlStatus}"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="MSSQL" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="{Binding MsSqlStatus}" Classes="statusText" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#1E1E1E" CornerRadius="8" Padding="12" Margin="5" Height="65">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Ellipse Width="10" Height="10" Classes="statusDot" Tag="{Binding MongoDbStatus}"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="MongoDB" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="{Binding MongoDbStatus}" Classes="statusText" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>

            <Separator Background="#333333" />

            <StackPanel Spacing="10">
                <TextBlock Text="RESOURCES" Foreground="Gray" FontSize="10" FontWeight="Bold" />
                <Border Background="#1E1E1E" Padding="12" CornerRadius="8">
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBlock Text="CPU Cores" Foreground="White" />
                        <TextBlock Grid.Column="1" Text="{Binding Stats.ProcessorCount}" Foreground="Cyan" FontWeight="Bold" />
                    </Grid>
                </Border>
                <Border Background="#1E1E1E" Padding="12" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="RAM Usage" Foreground="White" />
                            <TextBlock Grid.Column="1" Text="{Binding MemoryDisplay}" Foreground="MediumPurple" FontWeight="Bold" />
                        </Grid>
                        <ProgressBar Value="{Binding MemoryUsedBytes}" Maximum="{Binding Stats.TotalMemoryBytes, FallbackValue=100}" Height="8" Foreground="MediumPurple" Background="#333333" CornerRadius="4" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="15">
                <TextBlock Text="STORAGE UNITS" Foreground="Gray" FontSize="10" FontWeight="Bold" />
                <ItemsControl ItemsSource="{Binding Stats.Drives}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBlock Text="{Binding Name}" Foreground="Orange" FontWeight="Bold" />
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding UsedPercentage, StringFormat={}{0}% Used}" 
                                                   Foreground="Gray" FontSize="12" />
                                    </Grid>

                                    <ProgressBar Value="{Binding UsedPercentage}" 
                                                 Height="8" Minimum="0" Maximum="100" 
                                                 Foreground="#FF4500" Background="#333333" CornerRadius="4" />

                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <TextBlock Text="{Binding UsedGB, StringFormat={}{0} GB Used}" 
                                                   Foreground="#AAAAAA" FontSize="11" />
                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding TotalGB, StringFormat={}{0} GB Total}" 
                                                   Foreground="#666666" FontSize="11" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>